{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["@cloudflare/workers-types"],
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "vite.config.ts",
    "react-router.config.ts",
    "vite.config.d.ts",
    "worker.ts",
    "src/worker/**/*.ts",
    "src/types/**/*.d.ts"
  ]
}
